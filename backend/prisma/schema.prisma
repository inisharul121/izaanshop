generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  phone     String?
  street    String?
  city      String?
  state     String?
  zipCode   String?
  country   String?  @default("Bangladesh")
  wishlist  Product[] @relation("UserWishlist")
  orders    Order[]
  reviews   Review[]
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  image       String?
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum ProductType {
  SIMPLE
  VARIABLE
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String   @db.Text
  price       Float
  salePrice   Float?
  stock       Int      @default(0)
  isFeatured  Boolean  @default(false)
  images      Json?    
  rating      Float    @default(0)
  numReviews  Int      @default(0)
  
  type        ProductType @default(SIMPLE)
  attributes  ProductAttribute[]
  variants    ProductVariant[]
  
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  Int
  
  wishlistedBy User[]  @relation("UserWishlist")
  reviews      Review[]
  orderItems   OrderItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductAttribute {
  id        Int      @id @default(autoincrement())
  name      String   // e.g., "Color"
  options   Json     // e.g., ["Red", "Blue"]
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id          Int      @id @default(autoincrement())
  sku         String?  @unique
  price       Float
  salePrice   Float?
  stock       Int      @default(0)
  options     Json     // e.g., { "Color": "Red", "Size": "XL" }
  image       String?
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  name      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
}

model Order {
  id              Int      @id @default(autoincrement())
  totalPrice      Float
  paymentMethod   String
  itemsPrice      Float
  taxPrice        Float    @default(0)
  shippingPrice   Float    @default(0)
  isPaid          Boolean  @default(false)
  paidAt          DateTime?
  isDelivered     Boolean  @default(false)
  deliveredAt     DateTime?
  status          String   @default("Pending")
  
  // Shipping Address
  street          String?
  city            String?
  state           String?
  zipCode         String?
  country         String?   @default("Bangladesh")
  
  // Payment Result
  paymentId       String?
  transactionId   String?
  paymentStatus   String?
  paymentEmail    String?
  
  user            User?    @relation(fields: [userId], references: [id])
  userId          Int?
  
  // Guest order info (used when userId is null)
  guestName       String?
  guestEmail      String?
  guestPhone      String?
  
  // Phone (used for both guest and logged-in orders)
  phone           String?
  
  orderItems      OrderItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  name      String
  quantity  Int
  image     String
  price     Float
  
  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
}

model Coupon {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  discountType  String   // "percentage" or "fixed"
  discountValue Float
  expiryDate    DateTime?
  isActive      Boolean  @default(true)
  maxUses       Int?
  usedCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Settings {
  id            Int      @id @default(autoincrement())
  key           String   @unique
  value         String?
  updatedAt     DateTime @updatedAt
}
